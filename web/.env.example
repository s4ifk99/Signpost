# Copy to `.env.local` for local dev (Next.js loads it automatically).
# `npm run sra:sync` and `npm run db:migrate` also load `.env` then `.env.local` from `web/`.
# Never commit real keys.

# --- SRA Data Share (ingest only: `npm run sra:sync`) ---
# Subscribe: https://sra-prod-apim.developer.azure-api.net
SRA_APIM_SUBSCRIPTION_KEY=

# --- MySQL (optional but recommended for sra:sync) ---
# When set, npm run sra:sync upserts table `sra_organisations` before each Meilisearch batch.
# Apply migrations first: cd web && npx prisma migrate deploy
# DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3306/DATABASE_NAME

# --- Meilisearch (search + ingest) ---
# Same values must be set where the app runs (Vercel, etc.) for /search to query SRA.
# Local Docker example: MEILI_MASTER_KEY must match MEILISEARCH_API_KEY below.
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_API_KEY=38a9b0966ec845b2b64191e47605d64c

# Optional: override GetAll URL (default is official APIM endpoint)
# SRA_ORGANISATIONS_URL=

# Optional: semantic search on curated listings
# HF_TOKEN=

# --- OpenAI (Whisper dictation + AI search refine on home; optional chat assistant) ---
# Required for POST /api/transcribe (Whisper) and POST /api/search/refine on the home page.
# OPENAI_API_KEY=
