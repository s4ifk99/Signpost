# Copy to `.env.local` for local dev (Next.js loads it automatically).
# `npm run sra:sync`, `npm run listings:sync-typesense`, and `npm run db:migrate` also load `.env` then `.env.local` from `web/`.
# Never commit real keys.

# --- SRA Data Share (ingest only: `npm run sra:sync`) ---
# Subscribe: https://sra-prod-apim.developer.azure-api.net
SRA_APIM_SUBSCRIPTION_KEY=

# --- MySQL (optional but recommended for sra:sync) ---
# When set, npm run sra:sync upserts table `sra_organisations` before each Meilisearch batch.
# Apply migrations first: cd web && npx prisma migrate deploy
# DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3306/DATABASE_NAME

# --- Meilisearch (optional: SRA ingest only via `npm run sra:sync`) ---
# Not used for /search (directory uses Fuse or Typesense for listings only).
# MEILISEARCH_HOST=http://127.0.0.1:7700
# MEILISEARCH_API_KEY=

# --- Typesense (optional: faster lexical search for directory listings) ---
# When TYPESENSE_HOST + TYPESENSE_API_KEY are set, /search and category filters query Typesense.
# After changing merged listings data, run: cd web && npm run listings:sync-typesense
# Cloud: hostname only (no https://). Local Docker often uses http + port 8108.
# TYPESENSE_HOST=localhost
# TYPESENSE_API_KEY=xyz
# TYPESENSE_PROTOCOL=http
# TYPESENSE_PORT=8108

# Optional: override GetAll URL (default is official APIM endpoint)
# SRA_ORGANISATIONS_URL=

# Optional: semantic search on curated listings
# HF_TOKEN=
